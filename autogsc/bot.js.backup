// ===== acfolder integration paths =====
const ACFOLDER_RESULT_PATH = path.resolve(__dirname, process.env.ACFOLDER_RESULT_PATH || '../acfolder/result/template_result');
const ACFOLDER_TARGETS_FILE = path.resolve(__dirname, process.env.ACFOLDER_TARGETS_FILE || '../acfolder/domain_target.txt');
const ACFOLDER_GENERATOR_URL = process.env.ACFOLDER_GENERATOR_URL || '';

const TOKEN = process.env.TELEGRAM_TOKEN;
if (!TOKEN) {
  console.error('❌ TELEGRAM_TOKEN missing. Copy .env.example to .env and fill it.');
  process.exit(1);
}

const ALLOWED = (process.env.ALLOWED_USER_IDS || '')
  .split(',').map(s => s.trim()).filter(Boolean).map(Number);

const bot = new Telegraf(TOKEN);

// Simple ACL
bot.use(async (ctx, next) => {
  if (ALLOWED.length && !ALLOWED.includes(ctx.from?.id)) {
    return ctx.reply(`❌ Access denied. Your ID: ${ctx.from?.id}`);
  }
  return next();
});

// ============================================
// GLOBAL middleware: hanya tambah disable_web_page_preview (NO force parse_mode)
// parse_mode di-set per command secara manual kalau perlu
// ============================================
bot.use(async (ctx, next) => {
  const origReply = ctx.reply.bind(ctx);
  ctx.reply = (text, extra = {}) => {
    // Only add disable_web_page_preview, gak force parse_mode
    return origReply(text, {
      disable_web_page_preview: true,
      ...extra,
    });
  };

  const origEdit = ctx.telegram.editMessageText.bind(ctx.telegram);
  ctx.telegram.editMessageText = (chatId, msgId, inlineId, text, extra = {}) => {
    return origEdit(chatId, msgId, inlineId, text, {
      disable_web_page_preview: true,
      ...extra,
    });
  };

  return next();
});

// Global error handler — show errors di terminal + chat
bot.catch((err, ctx) => {
  console.error('❌ BOT ERROR:', err);
  try {
    ctx.reply(`❌ Bot error: ${err.message || err}\n\nCheck terminal log.`);
  } catch {}
});

// Catch unhandled exceptions
process.on('unhandledRejection', (reason, promise) => {
  console.error('❌ UNHANDLED REJECTION:', reason);
});
process.on('uncaughtException', (err) => {
  console.error('❌ UNCAUGHT EXCEPTION:', err);
});

// Lock per-domain biar gak double-run
const locks = new Set();
function withLock(domain, fn) {
  return async (ctx) => {
    if (locks.has(domain)) return ctx.reply(`⏳ Domain ${domain} masih diproses. Tunggu dulu.`);
    locks.add(domain);
    try { await fn(ctx); }
    finally { locks.delete(domain); }
  };
}

