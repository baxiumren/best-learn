// ============================================
// [5] ASSETS WIZARD
// ============================================

bot.command('showassets', (ctx) => {
  const a = editor.readAssets();
  if (!a) return ctx.reply('❌ index.php not found');
  let msg = `🎨 *Current Assets* (index.php defaults)\n\n`;
  for (const k of editor.ASSET_KEYS) {
    msg += `*${k}:*\n\`${a[k] || '(empty)'}\`\n\n`;
  }
  ctx.reply(msg);
});

bot.command('setassets', (ctx) => {
  const curr = editor.readAssets() || {};
  promptState.set(ctx.from.id, {
    kind: 'set-assets',
    step: 0,
    current: curr,
    updates: {},
  });
  askNextAsset(ctx);
});

function askNextAsset(ctx) {
  const st = promptState.get(ctx.from.id);
  if (!st || st.kind !== 'set-assets') return;
  if (st.step >= editor.ASSET_KEYS.length) {
    // Done — apply
    const results = editor.writeAssetsBulk(st.updates);
    promptState.delete(ctx.from.id);
    let msg = `✅ *Assets Updated*\n\n`;
    if (results.length === 0) {
      msg += `_(no changes)_`;
    } else {
      results.forEach(r => {
        msg += `${r.ok ? '✅' : '❌'} *${r.key}*: \`${r.value}\`\n`;
        if (!r.ok) msg += `   _${r.error}_\n`;
      });
    }
    return ctx.reply(msg);
  }
  const key = editor.ASSET_KEYS[st.step];
  const cur = st.current[key] || '(empty)';
  ctx.reply(
    `🎨 *[${st.step + 1}/${editor.ASSET_KEYS.length}] ${key}*\n\n` +
    `Current: \`${cur}\`\n\n` +
    `Kirim URL baru, atau \`/skip\` untuk gak ubah, atau \`/cancel\`.`
  );
}

bot.command('skip', (ctx) => {
  const st = promptState.get(ctx.from.id);
  if (st?.kind !== 'set-assets') return ctx.reply('🚫 Gak ada wizard aktif');
  st.step++;
  askNextAsset(ctx);
});

// ============================================
// [6] GEN-SITEMAP — copy targets, trigger PHP, return XML
// ============================================

bot.command('gensitemap', async (ctx) => {
  const msg = await ctx.reply('🗺️ Generating sitemap...');
  try {
    // 1. Copy domain_target.txt → sitemap_domain.txt
    const cp = editor.copyTargetsToSitemap();

    // 2. Trigger PHP generator via HTTP (kalo URL ada)
    const url = process.env.ACFOLDER_SITEMAP_GEN_URL;
    let phpStatus = 'skipped (no ACFOLDER_SITEMAP_GEN_URL)';
    if (url) {
      try {
        const res = await axios.get(url, { timeout: 30000 });
        phpStatus = `HTTP ${res.status}`;
      } catch (e) {
        phpStatus = `error: ${e.message}`;
      }
    }

    // 3. Read result
    const out = editor.readSitemapOutput();

    let report = `🗺️ *Sitemap Generation*\n\n`;
    report += `📄 Copied: \`${path.basename(cp.dest)}\` (${cp.lineCount} URL)\n`;
    report += `🔨 PHP gen: ${phpStatus}\n`;
    if (out) {
      report += `✅ Output: \`${path.basename(out.file)}\`\n`;
      report += `📏 Size: ${(out.size / 1024).toFixed(1)} KB\n`;
      report += `🕒 Modified: ${out.modified.toLocaleString()}\n`;
    } else {
      report += `⚠️ Output file gak ditemukan\n`;
    }
    report += `\n💡 Upload \`sitemap.xml\` ke root domain biar Google bisa baca.`;
    await ctx.telegram.editMessageText(ctx.chat.id, msg.message_id, null, report);

    // Attach sitemap.xml file
    if (out) {
      await ctx.replyWithDocument({ source: out.file, filename: 'sitemap.xml' });
    }
  } catch (e) {
    await ctx.telegram.editMessageText(ctx.chat.id, msg.message_id, null, `❌ ${e.message}`);
  }
});

// ============================================
// [original /edit untuk input files]
