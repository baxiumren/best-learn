// ============================================
// /scan <sitemap_url>
// ============================================
bot.command('scan', async (ctx) => {
  const sitemapUrl = ctx.message.text.split(/\s+/)[1];
  if (!sitemapUrl) return ctx.reply('Format: `/scan https://domain.com/sitemap.xml`');

  const msg = await ctx.reply('🔍 Fetching & analyzing sitemap...');
  try {
    const { data } = await axios.get(sitemapUrl, { timeout: 30000 });
    const result = await analyzeSitemap(data);

    // Cleanup old data buat domain ini sebelum save (re-scan = fresh start)
    deleteDomain(result.domain);
    saveDomainData(result.domain, result, data);

    let report = `📊 *Analysis Report*\n\n`;
    report += `🌐 Domain : \`${result.domain}\`\n`;
    report += `📄 Total URL : *${result.totalUrls}*\n`;
    report += `📂 Prefixes : *${result.prefixes.length}*\n`;
    report += `📁 GSC files needed : *${result.prefixes.length}*\n`;
    report += `⚡ Daily quota : *${result.prefixes.length * 10}* URL/hari\n`;
    report += `📅 Days to index all : *${Math.ceil(result.totalUrls / (result.prefixes.length * 10))}*\n\n`;
    report += `*Detected prefixes:*\n`;
    result.prefixes.forEach((p, i) => {
      const count = (result.urlsByPrefix[p] || []).length;
      report += `${i + 1}. \`${p}\` — ${count} URL\n`;
    });
    report += `\n👉 Next: \`/prepare ${result.domain}\``;

    await ctx.telegram.editMessageText(ctx.chat.id, msg.message_id, null, report);
  } catch (e) {
    await ctx.reply(`❌ Scan error: ${e.message}`);
  }
});

// ============================================
// INPUT FILE MANAGEMENT
// ============================================

// In-memory: track user yang lagi /edit atau /append (next text message = isi)
const editingState = new Map(); // userId -> { type, mode: 'edit'|'append' }
const uploadingState = new Map(); // userId -> { type }

function getTypeFromArg(arg) {
  if (!arg) return null;
  const t = arg.toLowerCase();
  if (['targets', 'target', 'domain', 'domains'].includes(t)) return 'targets';
  if (['brands', 'brand'].includes(t)) return 'brands';
  if (['images', 'image', 'img'].includes(t)) return 'images';
  return null;
}

bot.command('show', (ctx) => {
  const type = getTypeFromArg(ctx.message.text.split(/\s+/)[1]);
  if (!type) return ctx.reply('Format: /show <targets|brands|images>');

  const data = inputs.read(type);
  if (!data.exists) return ctx.reply(`❌ File belum ada: ${inputs.INPUT_TYPES[type].label}`);

  const preview = data.lines.slice(0, 30).join('\n');
  const more = data.lines.length > 30 ? `\n\n(... +${data.lines.length - 30} lebih)` : '';
  ctx.reply(
    `📄 ${inputs.INPUT_TYPES[type].label} (${data.lines.length} baris)\n\n${preview}${more}`
  );
});

bot.command('check', (ctx) => {
  const result = inputs.validateAll();
  let txt = `🔎 *Input Validation*\n\n`;
  txt += `📄 Targets : ${result.targets} URL\n`;
  txt += `🏷️ Brands  : ${result.brands} brand\n`;
  txt += `🖼️ Images  : ${result.images} URL\n\n`;
  if (result.ok) {
    txt += `✅ *Semua sinkron* (${result.targets} entries)\n`;
    txt += `_Siap di-generate lewat acfolder!_`;
  } else {
    txt += `⚠️ *Ada masalah:*\n`;
    result.issues.forEach(i => txt += `• ${i}\n`);
  }
  ctx.reply(txt);
});

